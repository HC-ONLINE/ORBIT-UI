---
type Align = "left" | "center" | "right";

const { align = "left", class: className = "" } = Astro.props as {
  align?: Align;
  class?: string;
};

const alignClasses: Record<Align, string> = {
  left: "text-left",
  center: "text-center",
  right: "text-right",
};

const classes = [
  "px-4",
  "py-3",
  "text-xs",
  "font-medium",
  "text-(--color-text-muted)",
  "uppercase",
  "tracking-wide",
  "border-b",
  "border-(--color-surface-stroke)",
  alignClasses[align],
  className,
]
  .filter(Boolean)
  .join(" ");
---

<th scope="col" class={classes}>
  <slot />
</th>
