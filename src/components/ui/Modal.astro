---
const { id, class: className = "" } = Astro.props as {
  id?: string;
  class?: string;
};

const dialogClasses = [
  "rounded-lg",
  "border",
  "border-(--color-surface-stroke)",
  "bg-(--color-surface-elevated)",
  "p-6",
  "w-full",
  "max-w-lg",
  "shadow-lg",
  "backdrop:bg-black/40",
  className,
]
  .filter(Boolean)
  .join(" ");
---

<dialog id={id} class={dialogClasses}>
  <div class="flex items-start justify-between gap-4">
    {
      Astro.slots.title && (
        <div class="text-base font-semibold text-(--color-text-primary)">
          <slot name="title" />
        </div>
      )
    }

    <form method="dialog" class="ml-auto shrink-0">
      <button
        type="submit"
        class="flex items-center justify-center rounded-md p-1 text-(--color-text-muted) transition-colors hover:text-(--color-text-primary)"
        aria-label="Cerrar"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>
    </form>
  </div>

  <div class="mt-2 text-sm text-(--color-text-muted)">
    <slot />
  </div>

  {
    Astro.slots.actions && (
      <div class="mt-5 flex justify-end gap-2">
        <slot name="actions" />
      </div>
    )
  }
</dialog>

<style>
  dialog {
    position: fixed;
    inset: 0;
    margin: auto;
    height: fit-content;
    max-height: calc(100dvh - 2rem);
    overflow-y: auto;
  }
</style>
